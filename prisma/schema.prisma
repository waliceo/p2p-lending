generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LoanStatus {
  DRAFT
  PENDING_SIGNATURES
  ACTIVE
  COMPLETED
  DEFAULTED
  CANCELLED
}

enum PaymentStatus {
  UPCOMING
  DUE
  PAID
  LATE
  MISSED
}

enum PaymentMethod {
  MANUAL
  BANK_TRANSFER
  OTHER
}

enum RepaymentFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  CUSTOM
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  DECLINED
}

enum InvitationRole {
  BORROWER
  LENDER
}

enum NotificationType {
  PAYMENT_DUE_SOON
  PAYMENT_OVERDUE
  PAYMENT_RECEIVED
  LOAN_INVITATION
  LOAN_SIGNED
  LOAN_COMPLETED
}

model User {
  id          String   @id @default(uuid()) @db.Uuid
  email       String   @unique
  fullName    String   @map("full_name")
  phone       String?
  avatarUrl   String?  @map("avatar_url")
  paymentInfo Json?    @map("payment_info")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  loansAsBorrower Loan[]           @relation("BorrowerLoans")
  loansAsLender   Loan[]           @relation("LenderLoans")
  notifications   Notification[]
  invitations     LoanInvitation[] @relation("InviterInvitations")

  @@map("users")
}

model Loan {
  id                 String             @id @default(uuid()) @db.Uuid
  borrowerId         String?            @map("borrower_id") @db.Uuid
  lenderId           String?            @map("lender_id") @db.Uuid
  amount             Decimal            @db.Decimal(12, 2)
  interestRate       Decimal            @default(0) @map("interest_rate") @db.Decimal(5, 2)
  repaymentFrequency RepaymentFrequency @map("repayment_frequency")
  startDate          DateTime           @map("start_date") @db.Date
  endDate            DateTime           @map("end_date") @db.Date
  gracePeriodDays    Int                @default(0) @map("grace_period_days")
  lateFeeAmount      Decimal            @default(0) @map("late_fee_amount") @db.Decimal(10, 2)
  status             LoanStatus         @default(DRAFT)
  notes              String?
  contractPdfUrl     String?            @map("contract_pdf_url")
  borrowerSignedAt   DateTime?          @map("borrower_signed_at")
  lenderSignedAt     DateTime?          @map("lender_signed_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  borrower    User?            @relation("BorrowerLoans", fields: [borrowerId], references: [id])
  lender      User?            @relation("LenderLoans", fields: [lenderId], references: [id])
  payments    Payment[]
  invitations LoanInvitation[]
  notifications Notification[]

  @@map("loans")
}

model Payment {
  id         String        @id @default(uuid()) @db.Uuid
  loanId     String        @map("loan_id") @db.Uuid
  amountDue  Decimal       @map("amount_due") @db.Decimal(10, 2)
  amountPaid Decimal       @default(0) @map("amount_paid") @db.Decimal(10, 2)
  dueDate    DateTime      @map("due_date") @db.Date
  paidDate   DateTime?     @map("paid_date") @db.Date
  status     PaymentStatus @default(UPCOMING)
  method     PaymentMethod?
  notes      String?
  createdAt  DateTime      @default(now()) @map("created_at")

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model LoanInvitation {
  id           String           @id @default(uuid()) @db.Uuid
  loanId       String           @map("loan_id") @db.Uuid
  inviterId    String           @map("inviter_id") @db.Uuid
  inviteeEmail String           @map("invitee_email")
  role         InvitationRole
  status       InvitationStatus @default(PENDING)
  token        String           @unique @default(uuid())
  expiresAt    DateTime         @map("expires_at")
  createdAt    DateTime         @default(now()) @map("created_at")

  loan    Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)
  inviter User @relation("InviterInvitations", fields: [inviterId], references: [id])

  @@map("loan_invitations")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  loanId    String?          @map("loan_id") @db.Uuid
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  loan Loan? @relation(fields: [loanId], references: [id], onDelete: SetNull)

  @@map("notifications")
}
